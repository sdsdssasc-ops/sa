# ============================================================
# مثال لمتغيرات البيئة — انسخه إلى ملف باسم .env وعدّل القيم
# (ملف .env نفسه محظور من الرفع على GitHub — ما بينشر أسرارك)
# ============================================================

# رابط قاعدة بيانات PostgreSQL
# محليًا: postgresql://المستخدم:كلمة_المرور@localhost:5432/taafy
# من Render/Neon: ينسخ جاهز من لوحتهم
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taafy

# مفتاح سري طويل عشوائي لتشفير جلسات الدخول (غيّره لأي نص طويل)
JWT_SECRET=ضع-هنا-نصا-عشوائيا-طويلا-جدا-123456789

# بيانات حساب الأدمن الافتراضي (يتنشأ تلقائيًا عند أول تشغيل)
ADMIN_EMAIL=admin@taafy.local
ADMIN_PASSWORD=admin123456

# بيئة التشغيل
NODE_ENV=development
